{
  "name": "@agentflow/desktop",
  "version": "0.1.0",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently \"tsc -w\" \"wait-on dist/electron/main.js && electron .\"",
    "build": "tsc",
    "build:win": "tsc && electron-builder --win",
    "clean": "rimraf dist release"
  },
  "dependencies": {
    "@agentflow/core": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "concurrently": "^8.0.0",
    "wait-on": "^7.0.0",
    "typescript": "^5.4.0",
    "rimraf": "^5.0.0"
  }
}
