{
  "name": "@runnio/desktop",
  "version": "0.1.0",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "node scripts/build-renderer.mjs",
    "build:win": "node scripts/build-renderer.mjs && electron-builder --win",
    "start": "electron .",
    "dev": "cross-env RUNNIO_DEV=true node scripts/build-renderer.mjs && cross-env RUNNIO_DEV=true electron .",
    "clean": "rimraf dist release"
  },
  "dependencies": {
    "@runnio/core": "workspace:*",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.33.0",
    "xterm": "5.3.0",
    "xterm-addon-fit": "0.8.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^8.0.0",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "esbuild": "^0.27.4",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "wait-on": "^7.0.0"
