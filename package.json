{
  "name": "regent",
  "private": true,
  "description": "Orchestrate multiple Claude Code agents in parallel with git worktrees",
  "keywords": ["cli", "tui", "claude", "agent", "worktree", "electron"],
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "build": "pnpm -r build",
    "dev:tui": "pnpm --filter @regent/tui dev",
    "dev:desktop": "pnpm --filter @regent/desktop dev",
    "clean": "pnpm -r clean"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "node-pty"]
  }
}
